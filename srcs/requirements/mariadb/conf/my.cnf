[mysqld]
# TCPネットワーク接続を有効化する
# (Alpineのデフォルト設定 mariadb-server.cnf で skip-networking が有効になっているため上書き)
# DockerネットワークからWordPressがTCPでMariaDBに接続できるようにするために必要
skip-networking = 0

# ネットワーク上のすべてのインターフェースでリッスン
# (Dockerネットワーク内からWordPressがアクセスできるようにするため)
bind-address = 0.0.0.0

# MariaDBのデータファイルの保存先 (Dockerボリュームがここにマウントされる)
datadir = /var/lib/mysql

# ソケットファイルの場所
socket = /run/mysqld/mysqld.sock

# プロセスIDファイルの場所
pid-file = /run/mysqld/mysqld.pid

# デフォルト文字コードをUTF-8に設定 (日本語等を扱うため)
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

[client]
# クライアントもUTF-8を使用
default-character-set = utf8mb4
